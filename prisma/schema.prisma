generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Rsvp {
  id          String   @id @default(uuid()) @db.Uuid
  salutation  String
  name        String
  phone       String   @unique
  access_code String  @unique
  created_at  DateTime @default(now()) @map("created_at")

  @@map("rsvps")
}

